TERM_PASSWORD=change-this-to-a-strong-password
SESSION_SECRET=change-this-to-a-random-secret
PORT=7681
BASE_PATH=/webshell

# Public URL origin for WebSocket CSRF protection (e.g. https://example.com)
# If unset, the server allows connections where Origin matches the Host header.
ALLOWED_ORIGIN=https://example.com

# Max concurrent terminal tabs per session (default: 10)
MAX_TABS=10

# Set to 'production' to enforce HTTPS-only session cookies
NODE_ENV=production
